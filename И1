<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>💪 Тренировки</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800&display=swap');

:root {
  /* Цвета Telegram с фолбеком на твой прототип */
  --bg: var(--tg-theme-bg-color, #0f0f0f);
  --secondary-bg: var(--tg-theme-secondary-bg-color, #1a1a1a);
  --text: var(--tg-theme-text-color, #efefef);
  --hint: var(--tg-theme-hint-color, #707579);
  --accent: var(--tg-theme-button-color, #c8ff47);
  --accent-text: var(--tg-theme-button-text-color, #000000);
  --border: var(--tg-theme-section-separator-color, #2a2a2a);
  
  --green: #4ade80;
  --blue: #60a5fa;
}

* { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Manrope', -apple-system, sans-serif;
  min-height: 100vh;
  padding-bottom: 100px;
}

.header {
  background: var(--bg);
  padding: 16px;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid var(--border);
}

.app-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px;
  letter-spacing: 2px;
  color: var(--accent);
}

.day-tab {
  flex: 1;
  padding: 10px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--secondary-bg);
  color: var(--hint);
  font-size: 10px;
  font-weight: 700;
  transition: all .2s;
}

.day-tab.active {
  background: var(--accent);
  color: var(--accent-text);
  border-color: var(--accent);
}

.exercise-card {
  background: var(--secondary-bg);
  border: 1px solid var(--border);
  border-radius: 16px;
  margin: 10px 12px;
  padding: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.exercise-card.done {
  opacity: 0.6;
  border-color: var(--green);
}

.ex-name {
  font-weight: 700;
  font-size: 14px;
}

.weight-val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px;
  color: var(--accent);
}

.ex-check {
  width: 32px;
  height: 32px;
  border-radius: 10px;
  border: 2px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.exercise-card.done .ex-check {
  background: var(--green);
  border-color: var(--green);
  color: #000;
}

/* Стилизация панелей ввода в стиле TG */
.weight-input-bar {
  display: none;
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--secondary-bg);
  border-top: 1px solid var(--border);
  padding: 15px;
  z-index: 1000;
  box-shadow: 0 -5px 15px rgba(0,0,0,0.2);
}

.weight-input-bar.open { display: flex; align-items: center; gap: 10px; }

.wib-input {
  flex: 1;
  background: var(--bg);
  border: 2px solid var(--accent);
  border-radius: 10px;
  color: var(--text);
  font-size: 24px;
  padding: 8px;
  text-align: center;
  outline: none;
}

.bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--bg);
  border-top: 1px solid var(--border);
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-btn {
  flex: 1;
  padding: 12px;
  background: none;
  border: none;
  color: var(--hint);
  font-size: 10px;
  font-weight: 700;
}

.nav-btn.active { color: var(--accent); }
</style>
</head>
<body>

<div class="header">
  <div class="app-title">PRO WORKOUT</div>
  <div id="dayTabs" style="display:flex; gap:8px; margin-top:12px;"></div>
</div>

<div id="workoutContent"></div>

<div class="weight-input-bar" id="weightInputBar">
  <input type="number" class="wib-input" id="wibInput" inputmode="decimal">
  <button onclick="closeWib()" style="background:var(--accent); border:none; padding:15px; border-radius:10px; font-weight:800">OK</button>
</div>

<nav class="bottom-nav">
  <button class="nav-btn active">ТРЕНИРОВКА</button>
  <button class="nav-btn">ИСТОРИЯ</button>
</nav>

<script>
const tg = window.Telegram.WebApp;
tg.ready();
tg.expand();

// Обновление цветов интерфейса под тему
document.body.style.backgroundColor = tg.themeParams.bg_color;

function haptic() {
    tg.HapticFeedback.impactOccurred('light');
}

// Твоя логика отрисовки (упрощенно для примера)
function renderWorkout() {
    // Здесь твой оригинальный JS код для отрисовки карточек
    // Не забудь добавить вызов haptic() при кликах
}

function openWib(exId) {
    const bar = document.getElementById('weightInputBar');
    const input = document.getElementById('wibInput');
    bar.classList.add('open');
    input.focus(); // Автофокус при открытии
    haptic();
}

function closeWib() {
    document.getElementById('weightInputBar').classList.remove('open');
    haptic();
}

// Инициализация
renderWorkout();
</script>
</body>
</html>
